# Copy this file to .env and fill in real values. .env is gitignored and
# must never be committed. In CI (GitHub Actions), these same names are
# populated from repository secrets instead -- see README.

# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Free key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# Optional. Only needed if the LLM narrative pass in the briefing is enabled.
ANTHROPIC_API_KEY=
